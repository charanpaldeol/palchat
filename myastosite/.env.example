# ---------------------------------------------------------------------------
# Database — set DATABASE_URL for local and Vercel production.
# Vercel: Project → Settings → Environment Variables (Production).
# ---------------------------------------------------------------------------
# Get pooled connection string from: https://console.neon.tech → Connection details
# See docs/neon-setup.md
# NEVER commit real credentials. Copy this file to .env and fill in values locally only.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ---------------------------------------------------------------------------
# Backend API URL (server-side only). Required when frontend and API are split.
# Local dev: http://localhost:3000 (run `cd api && npx vercel dev` first).
# Production: your deployed API URL (e.g. https://reclaim-api-xxx.vercel.app).
# ---------------------------------------------------------------------------
API_URL=http://localhost:3000
