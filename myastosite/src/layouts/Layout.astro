---
interface Props {
  title?: string;
  /** When true, adds robots noindex,nofollow (e.g. login, signup, my-account). */
  noindex?: boolean;
}

const { title = "Reclaim", noindex = false } = Astro.props as Props;
const user = Astro.locals.user;

import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <div class="app-root">
      <header class="site-header" id="site-header">
        <div class="app-container site-header-inner">
          <a href="/" class="logo-lockup">
            <img
              src="/logo.svg"
              alt=""
              class="logo-img"
              width="32"
              height="32"
            />
            <span class="logo-text">Reclaim</span>
          </a>
          <nav class="nav-links" aria-label="Main">
            <a
              href="/"
              class="nav-link"
            >
              Home
            </a>
            <a
              href="/about"
              class="nav-link"
            >
              About
            </a>
            <a
              href="/tech-stack"
              class="nav-link"
            >
              Tech stack
            </a>
            <a
              href="/blog"
              class="nav-link"
            >
              Essays
            </a>
            <a
              href="/comments"
              class="nav-link"
            >
              Your thoughts
            </a>
            <a
              href="/millet-guide"
              class="nav-link"
            >
              Millet guide
            </a>
          </nav>
          <div class="nav-cta">
            {user ? (
              <>
                <a href="/my-account" class="nav-link">
                  My account
                </a>
                <form
                  method="post"
                  action="/api/auth/logout"
                  class="nav-logout-form"
                >
                  <button type="submit" class="btn btn-secondary btn-nav">
                    Log out
                  </button>
                </form>
              </>
            ) : (
              <a href="/login" class="btn btn-primary">
                Login
              </a>
            )}
          </div>
        </div>
      </header>

      <main class="app-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="app-container">
          <div class="site-footer-grid">
            <div class="footer-logo">
              <div class="footer-logo-lockup">
                <img
                  src="/logo.svg"
                  alt=""
                  class="logo-img footer-logo-img"
                  width="32"
                  height="32"
                />
                <span class="logo-text">Reclaim</span>
              </div>
              <p class="body-text-small">
                A calm home for product ideas, essays, and tiny tools.
              </p>
            </div>
            <div class="footer-links">
              <span class="section-eyebrow">Product</span>
              <a href="/" class="footer-link">Home</a>
              <a href="/about" class="footer-link">About</a>
              <a href="/tech-stack" class="footer-link">Tech stack</a>
              <a href="/blog" class="footer-link">Essays</a>
            </div>
            <div class="footer-links">
              <span class="section-eyebrow">Contact</span>
              <a href="/comments" class="footer-link">Your thoughts</a>
              <a href="mailto:hello@reclaim.org" class="footer-link">Email</a>
            </div>
          </div>
          <div class="footer-meta">
            <span>
              &copy; {new Date().getFullYear()} Reclaim. All rights reserved.
            </span>
            <span>Built with Astro, React, and Postgres.</span>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

