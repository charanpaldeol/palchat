---
interface Props {
  title?: string;
}

const { title = 'Palchat' } = Astro.props;
const currentPath = Astro.url.pathname;

const isHome = currentPath === '/';
const isAbout = currentPath.startsWith('/about') && !currentPath.startsWith('/about/tech-stack');
const isTechStack = currentPath === '/tech-stack' || currentPath.startsWith('/about/tech-stack');
const isComments = currentPath.startsWith('/comments');
const isMilletGuide = currentPath.startsWith('/millet-guide');

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <link
          rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono&display=swap"
        />
      </head>
      <body>
        <div class="app-root">
          <header class="site-header" id="site-header">
            <div class="app-container site-header-inner">
              <a href="/" class="logo-lockup">
                <div class="logo-badge">
                  P
                </div>
                <span class="logo-text">Palchat</span>
              </a>
              <nav class="nav-links" aria-label="Main">
                <a
                  href="/"
                  class={`nav-link ${isHome ? 'nav-link--active' : ''}`}
                  aria-current={isHome ? 'page' : undefined}
                >
                  Home
                </a>
                <a
                  href="/about"
                  class={`nav-link ${isAbout ? 'nav-link--active' : ''}`}
                  aria-current={isAbout ? 'page' : undefined}
                >
                  About
                </a>
                <a
                  href="/tech-stack"
                  class={`nav-link ${isTechStack ? 'nav-link--active' : ''}`}
                  aria-current={isTechStack ? 'page' : undefined}
                >
                  Tech stack
                </a>
                <a
                  href="/comments"
                  class={`nav-link ${isComments ? 'nav-link--active' : ''}`}
                  aria-current={isComments ? 'page' : undefined}
                >
                  Comments demo
                </a>
                <a
                  href="/millet-guide"
                  class={`nav-link ${isMilletGuide ? 'nav-link--active' : ''}`}
                  aria-current={isMilletGuide ? 'page' : undefined}
                >
                  Millet guide
                </a>
              </nav>
            </div>
          </header>

          <main class="app-main">
            <slot />
          </main>

          <footer class="site-footer">
            <div class="app-container">
              <div class="site-footer-grid">
                <div class="footer-logo">
                  <span class="logo-text">Palchat</span>
                  <p class="body-text-small">
                    A calm home for product ideas, essays, and tiny tools.
                  </p>
                </div>
                <div class="footer-links">
                  <span class="section-eyebrow">Product</span>
                  <a href="/" class="footer-link">Home</a>
                  <a href="/about" class="footer-link">About</a>
                  <a href="/tech-stack" class="footer-link">Tech stack</a>
                </div>
                <div class="footer-links">
                  <span class="section-eyebrow">Contact</span>
                  <a href="/comments" class="footer-link">Comments demo</a>
                  <a href="mailto:hello@palchat.org" class="footer-link">Email</a>
                </div>
              </div>
              <div class="footer-meta">
                <span>© {new Date().getFullYear()} Palchat. All rights reserved.</span>
                <span>Built with Astro, React, and Postgres.</span>
              </div>
            </div>
          </footer>
        </div>
        <script>
          if (typeof window !== 'undefined') {
            const header = document.getElementById('site-header');
            if (header) {
              const onScroll = () => {
                if (window.scrollY > 0) {
                  header.classList.add('scrolled');
                } else {
                  header.classList.remove('scrolled');
                }
              };
              window.addEventListener('scroll', onScroll, { passive: true });
            }
          }
        </script>
      </body>
    </html>
