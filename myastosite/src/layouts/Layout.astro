---
interface Props {
  title?: string;
}

const { title = 'Palchat' } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-50 antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
          <a href="/" class="flex items-center gap-2">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-900 text-xs font-semibold text-slate-50 shadow-sm">
              P
            </div>
            <span class="text-sm font-semibold tracking-tight text-slate-900 sm:text-base">Palchat</span>
          </a>
          <nav class="flex items-center gap-3 text-xs text-slate-600 sm:gap-5 sm:text-sm">
            <a href="/" class="rounded-full px-3 py-1.5 text-slate-700 transition hover:bg-slate-100 hover:text-slate-900">
              Home
            </a>
            <a href="/about" class="rounded-full px-3 py-1.5 text-slate-700 transition hover:bg-slate-100 hover:text-slate-900">
              About
            </a>
            <a
              href="/about/tech-stack"
              class="rounded-full bg-slate-900 px-3 py-1.5 text-xs font-medium text-slate-50 shadow-sm transition hover:bg-slate-800 sm:text-sm"
            >
              Tech stack
            </a>
            <a
              href="/comments"
              class="rounded-full px-3 py-1.5 text-slate-700 transition hover:bg-slate-100 hover:text-slate-900"
            >
              Tech demo
            </a>
          </nav>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-slate-800">
        <div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
          <span>© {new Date().getFullYear()} Palchat. All rights reserved.</span>
          <div class="flex flex-wrap gap-4">
            <a href="mailto:hello@palchat.org" class="hover:text-slate-200">Contact</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
