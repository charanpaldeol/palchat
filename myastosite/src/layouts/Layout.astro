---
interface Props {
  title?: string;
}

const { title = 'Palchat' } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-50 antialiased">
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-slate-800 bg-slate-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-900">
              P
            </div>
            <span class="text-sm font-semibold tracking-tight sm:text-base">Palchat</span>
          </a>
          <nav class="flex items-center gap-4 text-xs text-slate-300 sm:text-sm">
            <a href="/" class="hover:text-slate-50">Home</a>
            <a href="/about" class="hover:text-slate-50">About</a>
            <a href="/comments" class="hover:text-slate-50">Tech demo</a>
          </nav>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-slate-800">
        <div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
          <span>© {new Date().getFullYear()} Palchat. All rights reserved.</span>
          <div class="flex flex-wrap gap-4">
            <a href="mailto:hello@palchat.org" class="hover:text-slate-200">Contact</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
