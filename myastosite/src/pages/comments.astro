---
import Layout from '../layouts/Layout.astro';
import { query } from '@/lib/db';

let comments: { id: number; comment: string | null }[] = [];
let dbError: string | null = null;
try {
  const response = await query('SELECT * FROM comments');
  comments = response.rows ?? [];
} catch (e) {
  dbError = e instanceof Error ? e.message : 'Database unavailable';
}
---

<Layout title="Comments – Palchat">
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="space-y-4">
      <h1 class="text-2xl font-semibold tracking-tight text-slate-50 sm:text-3xl">
        Comments demo
      </h1>
      <p class="text-sm text-slate-300 sm:text-base">
        A minimal example of Palchat reading from PostgreSQL. This page is intentionally simple: no forms, just a list
        of comments from the database.
      </p>

      {dbError ? (
        <p class="rounded-lg border border-red-500/40 bg-red-950/40 px-3 py-2 text-sm text-red-100">
          Database unavailable: {dbError}
        </p>
      ) : (
        <div class="mt-4 space-y-3">
          {comments.length === 0 ? (
            <p class="text-sm text-slate-400">No comments yet.</p>
          ) : (
            comments.map((comment) => (
              <div class="rounded-lg border border-slate-800 bg-slate-900/70 px-3 py-2 text-sm text-slate-100">
                <p>{comment.comment ?? ''}</p>
                <div class="mt-1 text-xs text-slate-500">ID {comment.id}</div>
              </div>
            ))
          )}
        </div>
      )}
    </div>
  </section>
</Layout>
