---
import Layout from '../layouts/Layout.astro';
import { query } from '@/lib/db';
import '../styles/global.css';

let comments: { id: number; comment: string | null }[] = [];
let dbError: string | null = null;
try {
  const response = await query('SELECT * FROM comments');
  comments = response.rows ?? [];
} catch (e) {
  dbError = e instanceof Error ? e.message : 'Database unavailable';
}
---

<Layout title="Comments – Palchat">
  <main class="main">
    <h1 class="title">Astro + Aurora PostgreSQL</h1>

    {dbError ? (
      <p class="error">Database unavailable: {dbError}</p>
    ) : (
      <div class="container">
        {comments.length === 0 ? (
          <p class="empty">No comments yet.</p>
        ) : (
          comments.map((comment) => (
            <div>
              <p>{comment.comment ?? ''}</p>
              <div class="metadata">{comment.id}</div>
            </div>
          ))
        )}
      </div>
    )}
  </main>
</Layout>

<style>
  .main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem;
    font-family: system-ui, sans-serif;
  }
  .title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .container > div {
    padding: 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }
  .metadata {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.5rem;
  }
  .error {
    color: #b91c1c;
    padding: 1rem;
    background: #fef2f2;
    border-radius: 0.5rem;
  }
  .empty {
    color: #6b7280;
  }
</style>
