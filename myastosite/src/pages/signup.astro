---
import Layout from "../layouts/Layout.astro";
import SignupForm from "../components/SignupForm";

if (Astro.locals.user) {
  return Astro.redirect("/my-account");
}

const searchParams = Astro.url.searchParams;
const error = searchParams.get("error");
const errorMessage =
  error === "username"
    ? "ID must be 2–64 characters and only letters, numbers, and underscores."
    : error === "password"
      ? "Password must be at least 6 characters."
      : error === "exists"
        ? "This ID is already taken. Choose another."
        : error === "1"
          ? "Something went wrong. Please try again."
          : null;
---

<Layout title="Create account – Reclaim" noindex>
  <section class="section">
    <div class="app-container" style="max-width: 420px;">
      <h1 class="page-hero-title" style="margin-bottom: var(--sp-2);">
        Create account
      </h1>
      <p class="page-hero-subtitle" style="margin-bottom: var(--sp-6);">
        Choose an ID and password. You’ll be logged in after signing up.
      </p>

      <SignupForm client:load serverError={errorMessage} />

      <p class="body-text-small" style="margin-top: var(--sp-5); color: var(--color-text-secondary);">
        Already have an account? <a href="/login">Log in</a>
      </p>
    </div>
  </section>
</Layout>
