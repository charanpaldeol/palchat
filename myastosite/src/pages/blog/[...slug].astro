---
import Layout from '../../layouts/Layout.astro';
import { getApiUrl } from '@/lib/api';
import { getBlogPostBySlug } from '@/lib/repositories/blogRepository';

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';

if (!slug) {
  return Astro.redirect('/blog');
}

let dbPost: Awaited<ReturnType<typeof getBlogPostBySlug>> = null;
const apiUrl = getApiUrl();
if (apiUrl) {
  const res = await fetch(`${apiUrl}/api/blog/${encodeURIComponent(slug)}`);
  if (res.ok) {
    const raw = await res.json();
    dbPost = {
      ...raw,
      created_at: new Date(raw.created_at),
      updated_at: raw.updated_at ? new Date(raw.updated_at) : null,
    };
  }
} else {
  dbPost = await getBlogPostBySlug(slug);
}

if (!dbPost) {
  return new Response(null, { status: 404 });
}

const title = dbPost.title;
const pubDate = dbPost.created_at;
const updatedDate = dbPost.updated_at ?? undefined;
---

<Layout title={title}>
  <div class="app-container">
    <article class="blog-article">
      <header class="blog-article-header">
        <p class="section-eyebrow">Essay</p>
        <h1 class="blog-article-title">{title}</h1>
        <p class="blog-article-meta">
          {pubDate.toLocaleDateString('en-US', {
            month: 'short',
            day: '2-digit',
            year: 'numeric',
          })}
          {updatedDate && (
            <>
              {' · Updated '}
              {updatedDate.toLocaleDateString('en-US', {
                month: 'short',
                day: '2-digit',
                year: 'numeric',
              })}
            </>
          )}
        </p>
      </header>

      <div class="blog-article-body">
        <div set:html={dbPost.content_html} />
      </div>
    </article>
  </div>
</Layout>