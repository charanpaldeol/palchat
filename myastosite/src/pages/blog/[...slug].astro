---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getBlogPostBySlug } from '@/lib/repositories/blogRepository';

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';

if (!slug) {
  return Astro.redirect('/blog');
}

const mdPosts = await getCollection('blog');
const mdPost = mdPosts.find((p) => p.slug === slug) ?? null;

let title: string;
let pubDate: Date;
let updatedDate: Date | undefined;
let Content: any = null;
let dbPost: Awaited<ReturnType<typeof getBlogPostBySlug>> | null = null;

if (mdPost) {
  const rendered = await mdPost.render();
  Content = rendered.Content;
  title = mdPost.data.title;
  pubDate = mdPost.data.pubDate;
  updatedDate = mdPost.data.updatedDate;
} else {
  dbPost = await getBlogPostBySlug(slug);
  if (!dbPost) {
    return new Response(null, { status: 404 });
  }
  title = dbPost.title;
  pubDate = dbPost.created_at;
  updatedDate = dbPost.updated_at ?? undefined;
}
---

<Layout title={title}>
  <div class="app-container">
    <article class="blog-article">
      <header class="blog-article-header">
        <p class="section-eyebrow">Essay</p>
        <h1 class="blog-article-title">{title}</h1>
        <p class="blog-article-meta">
          {pubDate.toLocaleDateString('en-US', {
            month: 'short',
            day: '2-digit',
            year: 'numeric',
          })}
          {updatedDate && (
            <>
              {' · Updated '}
              {updatedDate.toLocaleDateString('en-US', {
                month: 'short',
                day: '2-digit',
                year: 'numeric',
              })}
            </>
          )}
        </p>
      </header>

      <div class="blog-article-body">
        {mdPost ? <Content /> : <div set:html={dbPost!.content_html} />}
      </div>
    </article>
  </div>
</Layout>