---
import Layout from '../layouts/Layout.astro';
import { getApiUrl } from '@/lib/api';
import { listBlogPosts } from '@/lib/repositories/blogRepository';

let dbPosts: { slug: string; title: string; description: string; created_at: Date }[] = [];
const apiUrl = getApiUrl();
if (apiUrl) {
  try {
    const res = await fetch(`${apiUrl}/api/blog`);
    if (res.ok) {
      const raw = await res.json();
      dbPosts = raw.map((p: { created_at: string }) => ({ ...p, created_at: new Date(p.created_at) }));
    }
  } catch (error) {
    console.error('Failed to load blog posts', error);
  }
} else {
  try {
    dbPosts = await listBlogPosts();
  } catch (error) {
    console.error('Failed to load blog posts', error);
  }
}

const user = Astro.locals.user;
---

<style>
  .blog-login-cta {
    color: var(--color-primary);
    font-weight: 500;
    margin-left: 0.25em;
  }
  .blog-login-cta:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
  }
</style>
<Layout title="Essays">
  <div class="app-container">
    <section class="page-hero">
      <h1 class="page-hero-title">Essays & updates</h1>
      <p class="page-hero-subtitle">
        Long-form thoughts on reclaiming our digital destiny, product notes, and tiny experiments.
      </p>
      <div class="blog-hero-actions" style="margin-top: var(--sp-4);">
        {user ? (
          <a href="/blog/new" class="btn btn-secondary">
            Write a new essay
          </a>
        ) : (
          <p class="body-text-small" style="color: var(--color-text-secondary); margin: 0;">
            Anyone with an account can contribute.
            <a href="/login?redirect=/blog/new" class="blog-login-cta">Log in to write an essay</a>
          </p>
        )}
      </div>
    </section>

    <section class="section">
      <div class="blog-grid">
        {
          dbPosts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card card-clickable blog-card">
              <h2 class="blog-card-title">{post.title}</h2>
              <p class="blog-card-meta">
                {post.created_at.toLocaleDateString('en-US', {
                  month: 'short',
                  day: '2-digit',
                  year: 'numeric',
                })}
              </p>
              <p class="blog-card-description">{post.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>