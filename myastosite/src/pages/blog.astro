---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Essays">
  <div class="app-container">
    <section class="page-hero">
      <h1 class="page-hero-title">Essays & updates</h1>
      <p class="page-hero-subtitle">
        Long-form thoughts on reclaiming our digital destiny, product notes, and tiny experiments.
      </p>
    </section>

    <section class="section">
      <div class="blog-grid">
        {
          posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card card-clickable blog-card">
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-meta">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  month: 'short',
                  day: '2-digit',
                  year: 'numeric',
                })}
              </p>
              <p class="blog-card-description">{post.data.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Layout>

