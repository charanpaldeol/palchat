---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { listBlogPosts } from '@/lib/repositories/blogRepository';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const dbPosts = await listBlogPosts();
const user = Astro.locals.user;
---

<Layout title="Essays">
  <div class="app-container">
    <section class="page-hero">
      <h1 class="page-hero-title">Essays & updates</h1>
      <p class="page-hero-subtitle">
        Long-form thoughts on reclaiming our digital destiny, product notes, and tiny experiments.
      </p>
      {user && (
        <div style="margin-top: var(--sp-4);">
          <a href="/blog/new" class="btn btn-secondary">
            Write a new essay
          </a>
        </div>
      )}
    </section>

    <section class="section">
      <div class="blog-grid">
        {
          posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card card-clickable blog-card">
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-meta">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  month: 'short',
                  day: '2-digit',
                  year: 'numeric',
                })}
              </p>
              <p class="blog-card-description">{post.data.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    {dbPosts.length > 0 && (
      <section class="section">
        <h2 class="section-title" style="margin-bottom: var(--sp-4);">
          Community essays
        </h2>
        <div class="blog-grid">
          {
            dbPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="card card-clickable blog-card">
                <h2 class="blog-card-title">{post.title}</h2>
                <p class="blog-card-meta">
                  {post.created_at.toLocaleDateString('en-US', {
                    month: 'short',
                    day: '2-digit',
                    year: 'numeric',
                  })}
                </p>
                <p class="blog-card-description">{post.description}</p>
              </a>
            ))
          }
        </div>
      </section>
    )}
  </div>
</Layout>