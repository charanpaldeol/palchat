---
import Layout from '../layouts/Layout.astro';
import MilletGuidePageBody from '@/components/pages/millet-guide/MilletGuidePageBody.astro';
---

<Layout title="Millet, flour & fat guide">
  <MilletGuidePageBody />

  <script>
    if (typeof window !== 'undefined') {
      window.showTab = function (t) {
        ['flours', 'fats', 'meals'].forEach(function (x) {
          var tab = document.getElementById('tab-' + x);
          var btn = document.getElementById('btn-' + x);
          if (tab) {
            tab.style.display = x === t ? 'block' : 'none';
          }
          if (btn) {
            btn.className = 'mg-tab-btn' + (x === t ? ' mg-tab-btn--active' : '');
          }
        });
      };
    }
  </script>
</Layout>
