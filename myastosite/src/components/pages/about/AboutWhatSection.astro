<section class="section-tight" style="padding-top: 0; padding-bottom: var(--sp-6);">
  <div class="app-container">
    <h2 class="section-title">
      What Palchat tries to do
    </h2>
    <ul class="body-text" style="margin-top: var(--sp-3);">
      <li style="display: flex; gap: var(--sp-2); margin-bottom: var(--sp-2);">
        <span
          style="margin-top: 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--color-text-secondary); flex-shrink: 0;"
        />
        <span
          ><span style="font-weight: 500;">Collect useful ideas</span> — focused on products that solo builders or small
          teams can realistically ship.</span
        >
      </li>
      <li style="display: flex; gap: var(--sp-2); margin-bottom: var(--sp-2);">
        <span
          style="margin-top: 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--color-text-secondary); flex-shrink: 0;"
        />
        <span
          ><span style="font-weight: 500;">Offer tiny SaaS-style tools</span> — simple utilities (like the Idea
          Prioritization Tool) that are free to use in the browser.</span
        >
      </li>
      <li style="display: flex; gap: var(--sp-2);">
        <span
          style="margin-top: 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--color-text-secondary); flex-shrink: 0;"
        />
        <span
          ><span style="font-weight: 500;">Stay low-friction</span> — no logins required for core exploration, no feeds,
          no infinite scrolling.</span
        >
      </li>
    </ul>
  </div>
</section>

