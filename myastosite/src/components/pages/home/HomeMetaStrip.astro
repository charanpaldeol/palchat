---
/** CTA strip + value props. Vision-aligned. */
---

<section class="home-meta">
  <div class="app-container">
    <div class="home-meta__ctas">
      <a href="#essay" class="btn btn-primary">
        Read the digital destiny essay
        <span aria-hidden="true">→</span>
      </a>
      <a href="/about" class="btn btn-secondary">
        Why we reject ad-driven feeds
      </a>
    </div>
    <div class="home-meta__strip">
      <div class="home-meta__item">
        <span class="section-eyebrow home-meta__label">Format</span>
        <p class="body-text-small home-meta__text">Essays and tools for reclaiming your stack.</p>
      </div>
      <div class="home-meta__item">
        <span class="section-eyebrow home-meta__label">Noise</span>
        <p class="body-text-small home-meta__text">No ads, no feeds, no dark patterns.</p>
      </div>
      <div class="home-meta__item">
        <span class="section-eyebrow home-meta__label">Audience</span>
        <p class="body-text-small home-meta__text">People who refuse to be just data points.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .home-meta {
    padding-top: var(--sp-5);
    padding-bottom: var(--sp-8);
  }

  .home-meta__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }

  .home-meta__ctas .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .home-meta__strip {
    display: grid;
    gap: var(--sp-5);
    grid-template-columns: 1fr;
    padding-top: var(--sp-5);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .home-meta__strip {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-6);
    }
  }

  .home-meta__item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .home-meta__label {
    margin: 0;
  }

  .home-meta__text {
    margin: 0;
  }
</style>
