---
/** Hero illustration: key + circle = ownership / reclaiming. Design-system colors only. */
---
<svg
  class="hero-illustration"
  viewBox="0 0 320 280"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Outer ring -->
  <circle cx="160" cy="140" r="110" stroke="var(--color-border)" stroke-width="1" fill="none" opacity="0.8" />
  <circle cx="160" cy="140" r="90" stroke="var(--color-border)" stroke-width="1" fill="var(--color-primary-light)" opacity="0.5" />
  <!-- Inner circle -->
  <circle cx="160" cy="140" r="70" fill="var(--color-bg)" stroke="var(--color-primary)" stroke-width="2" />
  <!-- Key: bow (circle) -->
  <circle cx="160" cy="115" r="22" stroke="var(--color-primary)" stroke-width="2" fill="none" />
  <!-- Key: shaft -->
  <path d="M160 93v-28" stroke="var(--color-primary)" stroke-width="2.5" stroke-linecap="round" />
  <!-- Key: teeth -->
  <path d="M160 65h14v6h-5v10h-4V71h-5v-6z" stroke="var(--color-primary)" stroke-width="1.5" fill="none" stroke-linejoin="round" />
  <!-- Small dot at center (focus) -->
  <circle cx="160" cy="140" r="4" fill="var(--color-primary)" opacity="0.6" />
</svg>
