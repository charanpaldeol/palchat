---
import { getApiUrl } from '@/lib/api';
import { query } from '@/lib/db';
import CommentForm from './CommentForm';

const searchParams = Astro.url.searchParams;
const justSaved = searchParams.get('success') === '1';
const hasError = searchParams.get('error') === '1';

let comments: { id: number; comment: string | null; created_at: string | null }[] = [];
let dbError: string | null = null;
const apiUrl = getApiUrl();

if (apiUrl) {
  try {
    const res = await fetch(`${apiUrl}/api/thoughts`);
    if (res.ok) comments = await res.json();
  } catch (e) {
    dbError = e instanceof Error ? e.message : 'API unavailable';
  }
} else {
  try {
    const response = await query('SELECT id, comment, created_at FROM thoughts ORDER BY created_at DESC, id DESC');
    comments = (response.rows ?? []) as typeof comments;
  } catch (e) {
    dbError = e instanceof Error ? e.message : 'Database unavailable';
  }
}
---

<section class="section">
  <div class="app-container" style="max-width: 720px;">
    <h1 class="section-title">
      Your thoughts
    </h1>
    <p class="body-text" style="margin-top: var(--sp-3);">
      This space is for you to share your thoughts about Reclaim and where it should go next. Anything you write here can be read by everyone using this page.
    </p>
    <p class="body-text" style="margin-top: var(--sp-3);">
      Type your thoughts below (up to 200 words) and save them. Recent thoughts from you and other people are listed underneath.
    </p>

    <CommentForm client:load justSaved={justSaved} hasError={hasError} />

    {dbError ? (
      <div class="alert alert-error" style="margin-top: var(--sp-4);">
        Database unavailable: {dbError}
      </div>
    ) : (
      <div style="margin-top: var(--sp-4); display: flex; flex-direction: column; gap: var(--sp-4);">
        {comments.length === 0 ? (
          <p class="body-text-small">
            No thoughts here yet. Be the first to sketch where Reclaim should go next.
          </p>
        ) : (
          comments.map((comment) => {
            const createdAt = comment.created_at ? new Date(comment.created_at) : null;
            const formatted =
              createdAt && !Number.isNaN(createdAt.getTime())
                ? createdAt.toLocaleString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                  })
                : null;

            return (
              <div class="card">
                <div
                  style="
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: var(--sp-3);
                    margin-bottom: var(--sp-2);
                  "
                >
                  <div style="display: flex; align-items: center; gap: var(--sp-2);">
                    <div
                      style="
                        width: 32px;
                        height: 32px;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        background: var(--color-primary-light);
                        color: var(--color-primary);
                        font-size: 0.75rem;
                        font-weight: 600;
                      "
                      aria-hidden="true"
                    >
                      A
                    </div>
                    <div class="body-text-small" style="color: var(--color-text-primary); font-weight: 500;">
                      Anonymous thinker
                    </div>
                  </div>
                  <div class="body-text-small" style="color: var(--color-text-disabled); white-space: nowrap;">
                    {formatted ? formatted : `ID ${comment.id}`}
                  </div>
                </div>
                <p class="body-text-small" style="margin: 0;">
                  {comment.comment ?? ''}
                </p>
              </div>
            );
          })
        )}
      </div>
    )}
  </div>
</section>
