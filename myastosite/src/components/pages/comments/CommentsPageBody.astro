---
import { query } from '@/lib/db';

const searchParams = Astro.url.searchParams;
const justSaved = searchParams.get('success') === '1';
const hasError = searchParams.get('error') === '1';

let comments: { id: number; comment: string | null; created_at: string | null }[] = [];
let dbError: string | null = null;
try {
  const response = await query('SELECT * FROM thoughts ORDER BY created_at DESC, id DESC');
  comments = response.rows ?? [];
} catch (e) {
  dbError = e instanceof Error ? e.message : 'Database unavailable';
}
---

<section class="section">
  <div class="app-container" style="max-width: 720px;">
    <h1 class="section-title">
      Your thoughts
    </h1>
    <p class="body-text" style="margin-top: var(--sp-3);">
      This space is for you to share your thoughts about Palchat and where it should go next. Anything you write here can be read by everyone using this page.
    </p>
    <p class="body-text" style="margin-top: var(--sp-3);">
      Type your thoughts below (up to 200 words) and save them. Recent thoughts from you and other people are listed underneath.
    </p>

    {justSaved && (
      <div class="alert alert-success" style="margin-top: var(--sp-3);">
        Saved. Your comment has been stored in the database.
      </div>
    )}

    {hasError && (
      <div class="alert alert-error" style="margin-top: var(--sp-3);">
        Please enter between 1 and 200 words before saving.
      </div>
    )}

    <form
      method="post"
      action="/api/add-comment?redirect=/comments"
      style="margin-top: var(--sp-4); display: flex; flex-direction: column; gap: var(--sp-4);"
    >
      <div class="field">
        <label for="comment" class="field-label">
          Your comment
        </label>
        <textarea
          id="comment"
          name="comment"
          class="input"
          rows="3"
          required
        ></textarea>
        <p class="field-helper">
          <span id="comment-word-count">0 / 200 words</span>. Empty comments or longer inputs will show an error and will not be saved.
        </p>
        <p class="field-error" id="comment-word-error" style="display: none;"></p>
      </div>

      <button type="submit" class="btn btn-primary">
        Save comment
      </button>
    </form>

    {dbError ? (
      <div class="alert alert-error" style="margin-top: var(--sp-4);">
        Database unavailable: {dbError}
      </div>
    ) : (
      <div style="margin-top: var(--sp-4); display: flex; flex-direction: column; gap: var(--sp-4);">
        {comments.length === 0 ? (
          <p class="body-text-small">
            No thoughts here yet. Be the first to sketch where Palchat should go next.
          </p>
        ) : (
          comments.map((comment) => {
            const createdAt = comment.created_at ? new Date(comment.created_at) : null;
            const formatted =
              createdAt && !Number.isNaN(createdAt.getTime())
                ? createdAt.toLocaleString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                  })
                : null;

            return (
              <div class="card">
                <div
                  style="
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: var(--sp-3);
                    margin-bottom: var(--sp-2);
                  "
                >
                  <div style="display: flex; align-items: center; gap: var(--sp-2);">
                    <div
                      style="
                        width: 32px;
                        height: 32px;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        background: var(--color-primary-light);
                        color: var(--color-primary);
                        font-size: 0.75rem;
                        font-weight: 600;
                      "
                      aria-hidden="true"
                    >
                      A
                    </div>
                    <div class="body-text-small" style="color: var(--color-text-primary); font-weight: 500;">
                      Anonymous thinker
                    </div>
                  </div>
                  <div class="body-text-small" style="color: var(--color-text-disabled); white-space: nowrap;">
                    {formatted ? formatted : `ID ${comment.id}`}
                  </div>
                </div>
                <p class="body-text-small" style="margin: 0;">
                  {comment.comment ?? ''}
                </p>
              </div>
            );
          })
        )}
      </div>
    )}
  </div>
</section>

<script>
  const MAX_WORDS = 200;

  function countWords(value) {
    const trimmed = value.trim();
    if (!trimmed) return 0;
    return trimmed.split(/\s+/).filter(Boolean).length;
  }

  if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', () => {
      const textarea = document.getElementById('comment');
      const form = textarea?.form;
      const countEl = document.getElementById('comment-word-count');
      const errorEl = document.getElementById('comment-word-error');

      if (!textarea || !form || !countEl || !errorEl) return;

      function updateState() {
        const words = countWords(textarea.value);
        countEl.textContent = `${words} / ${MAX_WORDS} words`;

        const hasError = words === 0 || words > MAX_WORDS;
        textarea.classList.toggle('input-error', hasError);

        if (hasError) {
          errorEl.style.display = 'block';
          if (words === 0) {
            errorEl.textContent = 'Please enter at least 1 word.';
          } else {
            errorEl.textContent = `Please keep comments to ${MAX_WORDS} words or fewer.`;
          }
        } else {
          errorEl.style.display = 'none';
          errorEl.textContent = '';
        }
      }

      textarea.addEventListener('input', updateState);

      form.addEventListener('submit', (event) => {
        const words = countWords(textarea.value);
        if (words === 0 || words > MAX_WORDS) {
          event.preventDefault();
          updateState();
        }
      });

      updateState();
    });
  }
</script>

