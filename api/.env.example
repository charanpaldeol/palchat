# Database (required for all API routes that use DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Allowed frontend origin(s) for Origin/Referer checks (comma-separated).
# When frontend is proxied via rewrite, the request may have this origin.
ALLOWED_ORIGINS=https://www.reclaim.org,https://reclaim.org,http://localhost:4321
